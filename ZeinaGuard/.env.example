# ==============================================================================
# ZeinaGuard - Environment Configuration Template
# ==============================================================================

# --- Database (PostgreSQL + TimescaleDB) ---
DB_USER=zeinaguard_user
DB_PASSWORD=secure_password_change_me
DB_NAME=zeinaguard_db
PGADMIN_PASSWORD=admin_password_change_me

# --- Backend (Flask + Socket.IO) ---
JWT_SECRET_KEY=generate_a_random_string_here
FLASK_ENV=production
REDIS_PASSWORD=redis_password_change_me

# --- Sensor (WIPS Sniffer) ---
# The interface name must match your host machine's WiFi interface (e.g., wlan0, wlp2s0)
SENSOR_INTERFACE=wlan0
ENABLE_CONTAINMENT=True

# --- Frontend (Next.js) ---
# Usually these don't need changes for standard Docker deployment
NEXT_PUBLIC_API_URL=/backend-api
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000
BACKEND_URL=http://flask-backend:5000
